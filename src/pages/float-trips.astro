---
import Layout from "../layouts/Layout.astro";
import { site } from "../config/site";

const trips = [
  {
    name: "Rockhouse to Trigger Gap",
    distance: "7.7 miles",
    duration: "5–6 hours",
    days: "1 day",
    description:
      "Beautiful float with crystal clear deep holes for swimming. Ozark Mountains, deciduous forests, gravel beds. Finale rapid at Trigger Gap and the famous swimming hole.",
    bestFor: "Families & beginners",
    shuttleNote: "",
    gradient: "from-forest via-forest-light to-river",
    image: "/images/trips/rockhouse.jpg",
  },
  {
    name: "Trigger Gap to The Farm",
    distance: "4.7 miles",
    duration: "4 hours",
    days: "1 day",
    description:
      "Shorter and faster float perfect for families, children, beginners, or those with time constraints. Great fishing and swimming holes along the way.",
    bestFor: "Families & beginners",
    shuttleNote: "",
    gradient: "from-river to-river-dark",
    image: "/images/trips/farm.jpg",
  },
  {
    name: "Trigger Gap to 62 Bridge",
    distance: "12.9 miles",
    duration: "1–2 days",
    days: "1–2 days",
    description:
      "Multi-day river camping adventure. Smallmouth bass fishing, bird watching, swimming, and total relaxation.",
    bestFor: "Adventurous paddlers",
    shuttleNote: "Additional shuttle fee",
    gradient: "from-forest to-earth",
  },
  {
    name: "Marshall Ford to Rock House",
    distance: "15.7 miles",
    duration: "2 days",
    days: "2 days",
    description:
      "Water level dependent — call to confirm availability. A stunning stretch of the upper Kings River through remote Ozark terrain.",
    bestFor: "Adventurous paddlers",
    shuttleNote: "$100 shuttle",
    gradient: "from-river-dark to-forest",
  },
  {
    name: "Marble to Rock House",
    distance: "27 miles",
    duration: "3 days / 2 nights",
    days: "3 days",
    description:
      "The ultimate Kings River experience. Longest trip offered, typically available spring or after rainfall. Unmatched scenery and solitude.",
    bestFor: "Adventurous paddlers",
    shuttleNote: "$100 shuttle",
    gradient: "from-forest-light to-river-dark",
  },
];
---

<Layout
  title={`Float Trip Options | ${site.name}`}
  description="From a few hours to three days — explore Kings River float trip options with Trigger Gap Outfitters. Canoe, kayak, raft & SUP trips near Eureka Springs, AR."

>
  {/* Page Header */}
  <section class="relative bg-gradient-to-br from-forest via-river-dark to-river py-20 sm:py-28">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,_var(--color-forest-light)_0%,_transparent_60%)] opacity-20"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-4">
        Float Trip Options
      </h1>
      <p class="text-lg sm:text-xl text-sand-light/90 max-w-2xl mx-auto leading-relaxed">
        From a few hours to three days — find your perfect Kings River adventure.
      </p>
    </div>
  </section>

  {/* Trip Cards */}
  <section class="py-16 sm:py-20 bg-warmwhite">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 space-y-8 lg:space-y-10">
      {trips.map((trip) => (
        <div class="bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow overflow-hidden flex flex-col lg:flex-row">
          {/* Trip image */}
          <div class={`h-56 lg:h-72 lg:w-80 xl:w-96 flex-shrink-0 bg-gradient-to-br ${trip.gradient} relative`}>
            {trip.image ? (
              <img src={trip.image} alt={trip.name} class="h-full w-full object-cover" />
            ) : (
              <div class="absolute inset-0 flex items-center justify-center">
                <svg class="w-16 h-16 text-white/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
            )}
          </div>

          {/* Content */}
          <div class="p-6 sm:p-8 flex flex-col flex-1">
            <h3 class="font-heading text-2xl sm:text-3xl font-bold text-forest mb-3">
              {trip.name}
            </h3>

            {/* Badges */}
            <div class="flex flex-wrap gap-2 mb-4">
              <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-river-light/15 text-river-dark text-sm font-medium rounded-full">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l5.447 2.724A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
                </svg>
                {trip.distance}
              </span>
              <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-sand-light text-earth text-sm font-medium rounded-full">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                {trip.duration}
              </span>
              <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-forest/10 text-forest text-sm font-medium rounded-full">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                {trip.days}
              </span>
              {trip.shuttleNote && (
                <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-sunset/10 text-sunset-dark text-sm font-medium rounded-full">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
                  </svg>
                  {trip.shuttleNote}
                </span>
              )}
            </div>

            <p class="text-earth leading-relaxed mb-4 flex-1">
              {trip.description}
            </p>

            <div class="flex flex-col sm:flex-row sm:items-center gap-4">
              <span class="inline-flex items-center gap-1.5 text-sm text-earth-light">
                <svg class="w-4 h-4 text-river" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
                Best for: <span class="font-medium text-earth">{trip.bestFor}</span>
              </span>
              <a
                href={site.booking.url} target="_blank" rel="noopener noreferrer"
                class="inline-flex items-center justify-center px-6 py-3 bg-sunset text-white font-semibold rounded-lg hover:bg-sunset-dark transition-colors shadow-sm hover:shadow-md sm:ml-auto"
              >
                Book This Trip
                <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  {/* Shuttle Schedule Note */}
  <section class="py-10 sm:py-12 bg-sand-light/40">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-start gap-4 bg-white rounded-xl p-6 shadow-sm border border-sand/40">
        <div class="flex-shrink-0 w-10 h-10 bg-river-light/20 rounded-full flex items-center justify-center">
          <svg class="w-5 h-5 text-river-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div>
          <h3 class="font-heading text-lg font-semibold text-forest mb-1">Shuttle Schedule</h3>
          <p class="text-earth leading-relaxed">
            Shuttles depart between <span class="font-semibold">8:00 AM</span> and <span class="font-semibold">2:00 PM</span> daily. Latest start time is 2:00 PM. Reservations required.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* CTA Banner */}
  <section class="py-16 sm:py-20 bg-gradient-to-br from-forest via-forest-light to-river">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-3xl sm:text-4xl font-bold text-white mb-4">
        Find Your Perfect Trip
      </h2>
      <p class="text-sand-light/90 text-lg mb-8 max-w-xl mx-auto">
        Not sure which float is right for you? Book online or give us a call and we'll help you plan the perfect day on the river.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={site.booking.url} target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center px-8 py-4 bg-sunset text-white text-lg font-semibold rounded-lg hover:bg-sunset-dark transition-colors shadow-md hover:shadow-lg"
        >
          Book Now
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href={site.phoneTel}
          class="inline-flex items-center gap-2 px-6 py-4 bg-white/10 text-white text-lg font-semibold rounded-lg hover:bg-white/20 transition-colors border border-white/25"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          {site.phone}
        </a>
      </div>
    </div>
  </section>
</Layout>
