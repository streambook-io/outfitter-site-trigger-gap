---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Contact & Directions | Trigger Gap Outfitters"
  description="Get directions, hours, and contact info for Trigger Gap Outfitters on the Kings River near Eureka Springs, Arkansas."
>
  <!-- Page Header -->
  <section class="relative bg-gradient-to-br from-forest via-forest-light to-river-dark py-20 lg:py-28">
    <div class="absolute inset-0 bg-black/20"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-bold text-white">
        Contact & Directions
      </h1>
      <p class="mt-4 text-lg sm:text-xl text-sand-light/90 max-w-2xl mx-auto">
        Come find us on the Kings River.
      </p>
    </div>
  </section>

  <!-- Contact Info Grid -->
  <section class="py-16 lg:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        <!-- Phone -->
        <div class="bg-white rounded-xl shadow-sm border border-sand/40 p-6 text-center">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-river/10 mb-4">
            <svg class="w-7 h-7 text-river-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <h3 class="font-heading text-lg font-bold text-forest mb-1">Phone</h3>
          <a href="tel:479-253-5444" class="text-earth hover:text-river-dark transition-colors text-lg font-medium">
            479-253-5444
          </a>
        </div>

        <!-- Email -->
        <div class="bg-white rounded-xl shadow-sm border border-sand/40 p-6 text-center">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-river/10 mb-4">
            <svg class="w-7 h-7 text-river-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="font-heading text-lg font-bold text-forest mb-1">Email</h3>
          <a href="mailto:triggergapoutfitters@gmail.com" class="text-earth hover:text-river-dark transition-colors break-all">
            triggergapoutfitters@gmail.com
          </a>
        </div>

        <!-- Address -->
        <div class="bg-white rounded-xl shadow-sm border border-sand/40 p-6 text-center">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-river/10 mb-4">
            <svg class="w-7 h-7 text-river-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="font-heading text-lg font-bold text-forest mb-1">Address</h3>
          <p class="text-earth">
            190 CR 539<br />
            Eureka Springs, AR 72632
          </p>
        </div>

        <!-- Hours -->
        <div class="bg-white rounded-xl shadow-sm border border-sand/40 p-6 text-center">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-river/10 mb-4">
            <svg class="w-7 h-7 text-river-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-heading text-lg font-bold text-forest mb-1">Hours</h3>
          <p class="text-earth">7 Days a Week</p>
          <p class="text-forest font-semibold text-lg">8 AM &ndash; 6 PM</p>
          <p class="text-sm text-earth-light mt-1">April through early September</p>
        </div>

        <!-- Social -->
        <div class="bg-white rounded-xl shadow-sm border border-sand/40 p-6 text-center sm:col-span-2 lg:col-span-2">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-river/10 mb-4">
            <svg class="w-7 h-7 text-river-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z" />
            </svg>
          </div>
          <h3 class="font-heading text-lg font-bold text-forest mb-3">Follow Us</h3>
          <div class="flex items-center justify-center gap-4">
            <a
              href="https://www.facebook.com/triggergapoutfitters"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-2.5 bg-forest text-white rounded-lg hover:bg-forest-light transition-colors font-medium"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
              </svg>
              Facebook
            </a>
            <a
              href="https://www.instagram.com/triggergapoutfitters"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-2.5 bg-forest text-white rounded-lg hover:bg-forest-light transition-colors font-medium"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" />
              </svg>
              Instagram
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Directions -->
  <section class="py-16 lg:py-20 bg-sand-light/40">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-3xl sm:text-4xl font-bold text-forest text-center mb-10">
        Getting Here
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- From Eureka Springs -->
        <div class="bg-white rounded-xl shadow-sm border border-sand/40 p-6 sm:p-8">
          <div class="flex items-center gap-3 mb-4">
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-river/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-river-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
              </svg>
            </div>
            <h3 class="font-heading text-xl font-bold text-forest">From Eureka Springs</h3>
          </div>
          <p class="text-earth leading-relaxed">
            Take Highway 62 East toward Berryville, then turn right onto Rockhouse Road (CR-302) and follow it for approximately seven miles. At the fork, veer left to a stop sign, then turn left onto Highway 221. Continue a half-mile and look for our sign on the right. Turn right onto CR 509 and follow the dirt road roughly a half-mile until you see our sign on the left.
          </p>
        </div>

        <!-- From Berryville -->
        <div class="bg-white rounded-xl shadow-sm border border-sand/40 p-6 sm:p-8">
          <div class="flex items-center gap-3 mb-4">
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-river/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-river-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
              </svg>
            </div>
            <h3 class="font-heading text-xl font-bold text-forest">From Berryville</h3>
          </div>
          <p class="text-earth leading-relaxed">
            Get on State Highway 221 South and travel approximately eight miles, crossing the Kings River Bridge. After the hill, look for the first dirt road on the left with our sign. Turn left onto CR 509 and follow the dirt road roughly a half-mile until you see our sign on the left.
          </p>
        </div>
      </div>

      <!-- Lost note -->
      <div class="mt-8 text-center">
        <p class="inline-flex items-center gap-2 bg-white rounded-full px-6 py-3 shadow-sm border border-sand/40 text-earth">
          <svg class="w-5 h-5 text-river" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Lost? Give us a call at
          <a href="tel:479-253-5444" class="font-semibold text-river-dark hover:text-river transition-colors">
            479-253-5444
          </a>
          and we'll guide you in!
        </p>
      </div>
    </div>
  </section>

  <!-- Map Placeholder -->
  <section class="py-16 lg:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-3xl sm:text-4xl font-bold text-forest text-center mb-8">
        Find Us on the Map
      </h2>
      <!--
        TODO: Replace this placeholder with a Google Maps embed.
        Example:
        <iframe
          src="https://www.google.com/maps/embed?pb=YOUR_EMBED_ID"
          width="100%"
          height="450"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      -->
      <div class="bg-sand-light/60 rounded-xl border-2 border-dashed border-sand-dark/40 flex flex-col items-center justify-center py-24 sm:py-32">
        <svg class="w-16 h-16 text-sand-dark/50 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <p class="text-sand-dark font-medium text-lg">Map Coming Soon</p>
        <p class="text-earth-light text-sm mt-1">190 CR 539, Eureka Springs, AR 72632</p>
      </div>
    </div>
  </section>
</Layout>
