---
import Layout from "../layouts/Layout.astro";
import { site } from "../config/site";

const rentals = [
  {
    name: "Canoes",
    price: "$80",
    taxNote: "+tax",
    specs: ['16\' length', "Capacity: 1,835 lbs", "Fits 2 people + 1 dog or cooler"],
    gradient: "from-river to-river-dark",
    image: "/images/equipment/buffalo-canoe.jpg",
  },
  {
    name: "Jackson Riviera Solo Kayak",
    price: "$70",
    taxNote: "+tax",
    specs: ['11\'4" length', "Weight range: 90–300 lbs", "1 person"],
    gradient: "from-river-dark to-forest",
    image: "/images/equipment/singlekayak.jpg",
  },
  {
    name: "Jackson Supernatural SUP",
    price: "$75",
    taxNote: "+tax",
    specs: ["11.7' length", "Weight range: 90–350 lbs", "Extra stable — great for beginners"],
    gradient: "from-forest-light to-river",
    image: "/images/equipment/paddleboard.jpg",
  },
  {
    name: "Jackson Riviera T Tandem Kayak",
    price: "$80",
    taxNote: "+tax",
    specs: ['13\'8" length', "Weight range: 79–450 lbs", "2 people + small cooler", "No dogs"],
    gradient: "from-river to-forest-light",
    image: "/images/equipment/tandem-kayak.jpg",
  },
  {
    name: "Jackson Liska Fishing Kayak",
    price: "$100",
    taxNote: "+tax",
    specs: ['12\'1" length', "Weight range: 84–400 lbs", "Rod & tackle storage", "Stand or sit"],
    gradient: "from-forest to-earth",
    image: "/images/equipment/liska-fishing-kayak.jpg",
  },
  {
    name: "NRS Raft",
    price: "$200",
    taxNote: "",
    specs: ["Seats 4 adults comfortably with gear", "Holds up to 6 teens for group floats", "Dogs under 30 lbs welcome", "Water level dependent"],
    gradient: "from-river-dark to-river",
    image: "/images/equipment/raft.jpg",
  },
];

const privateFees = [
  { item: "Vehicle parking", price: "$10" },
  { item: "Trailer parking", price: "$10" },
  { item: "Per boat take-out", price: "$5" },
  { item: "Shuttle to Rock House / The Farm", price: "$35/vehicle" },
  { item: "Shuttle to 62 Bridge", price: "$55" },
  { item: "Shuttle to Marble", price: "$120" },
  { item: "Shuttle to Marshall Ford", price: "$130" },
];
---

<Layout
  title={`Rentals & Pricing | ${site.name}`}
  description="Premium canoe, kayak, raft & SUP rentals on the Kings River near Eureka Springs, AR. All rentals include shuttle, life jackets, recycling bag, and paddles."

>
  {/* Page Header */}
  <section class="relative bg-gradient-to-br from-forest via-forest-light to-river py-20 sm:py-28">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--color-river-light)_0%,_transparent_60%)] opacity-20"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-4">
        Rentals & Pricing
      </h1>
      <p class="text-lg sm:text-xl text-sand-light/90 max-w-2xl mx-auto leading-relaxed">
        Premium equipment for your Kings River adventure. All rentals include shuttle, life jackets, recycling bag, and paddles.
      </p>
    </div>
  </section>

  {/* Rental Cards Grid */}
  <section class="py-16 sm:py-20 bg-warmwhite">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-3xl sm:text-4xl font-bold text-forest text-center mb-12">
        Equipment Rentals
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {rentals.map((rental) => (
          <div class="bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow overflow-hidden flex flex-col">
            <div class={`h-48 bg-gradient-to-br ${rental.gradient} relative`}>
              {rental.image ? (
                <img src={rental.image} alt={rental.name} class="h-full w-full object-cover" />
              ) : (
                <div class="absolute inset-0 flex items-center justify-center">
                  <svg class="w-16 h-16 text-white/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                </div>
              )}
            </div>
            <div class="p-6 flex flex-col flex-1">
              <h3 class="font-heading text-xl font-semibold text-forest mb-2">{rental.name}</h3>
              <div class="mb-4">
                <span class="text-3xl font-bold text-sunset">{rental.price}</span>
                {rental.taxNote && (
                  <span class="text-sm text-earth-light ml-1">{rental.taxNote}</span>
                )}
              </div>
              <ul class="space-y-1.5 text-sm text-earth mb-6 flex-1">
                {rental.specs.map((spec) => (
                  <li class="flex items-start gap-2">
                    <svg class="w-4 h-4 text-river mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    {spec}
                  </li>
                ))}
              </ul>
              <a
                href={site.booking.url} target="_blank" rel="noopener noreferrer"
                class="block w-full text-center px-5 py-3 bg-sunset text-white font-semibold rounded-lg hover:bg-sunset-dark transition-colors shadow-sm hover:shadow-md"
              >
                Book Now
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Private Boater Fees */}
  <section class="py-16 sm:py-20 bg-sand-light/40">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-3xl sm:text-4xl font-bold text-forest text-center mb-10">
        Private Boater Fees
      </h2>
      <div class="bg-white rounded-xl shadow-md overflow-hidden">
        {privateFees.map((fee, i) => (
          <div
            class:list={[
              "flex items-center justify-between px-6 py-4",
              i < privateFees.length - 1 && "border-b border-sand/40",
            ]}
          >
            <span class="text-earth font-medium">{fee.item}</span>
            <span class="text-forest font-bold text-lg whitespace-nowrap ml-4">{fee.price}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Group Rates Banner */}
  <section class="py-12 sm:py-16 bg-gradient-to-r from-river-dark to-river">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-2xl sm:text-3xl font-bold text-white mb-4">
        Group Rates Available
      </h2>
      <p class="text-lg text-sand-light/90 mb-6 max-w-2xl mx-auto">
        Special pricing for groups over 10.
      </p>
      <a
        href={site.phoneTel}
        class="inline-flex items-center gap-2 px-6 py-3 bg-white text-river-dark font-semibold rounded-lg hover:bg-sand-light transition-colors shadow-sm hover:shadow-md"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        Call {site.phone}
      </a>
    </div>
  </section>

  {/* CTA */}
  <section class="py-16 sm:py-20 bg-warmwhite">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-3xl sm:text-4xl font-bold text-forest mb-4">
        Ready to Book?
      </h2>
      <p class="text-earth-light text-lg mb-8">
        Reserve your equipment and hit the Kings River.
      </p>
      <a
        href={site.booking.url} target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center px-8 py-4 bg-sunset text-white text-lg font-semibold rounded-lg hover:bg-sunset-dark transition-colors shadow-md hover:shadow-lg"
      >
        Book Now
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>
</Layout>
