---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Trigger Gap Outfitters | Kings River Kayak & Canoe Rentals | Eureka Springs, AR">
  <!-- ============================== -->
  <!-- HERO SECTION                   -->
  <!-- ============================== -->
  <section class="relative min-h-[80vh] flex items-center justify-center overflow-hidden">
    <!-- Gradient background simulating river/nature scene -->
    <div class="absolute inset-0 bg-gradient-to-br from-forest via-river-dark to-river">
      <!-- Layered overlay for depth -->
      <div class="absolute inset-0 bg-gradient-to-t from-forest/80 via-transparent to-river-dark/30"></div>
      <!-- Subtle light accents -->
      <div class="absolute inset-0 opacity-10 bg-[radial-gradient(circle_at_30%_70%,var(--color-river-light)_0%,transparent_50%),radial-gradient(circle_at_70%_30%,var(--color-forest-light)_0%,transparent_50%)]"></div>
    </div>

    <!-- Hero content -->
    <div class="relative z-10 mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-24 text-center text-white">
      <h1 class="font-heading text-4xl font-bold leading-tight tracking-tight sm:text-5xl lg:text-7xl">
        Adventure Awaits on the Kings River
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-white/90 sm:text-xl">
        Family-owned outfitter in the heart of the Ozarks. Canoes, kayaks,
        rafts &amp; stand-up paddleboards &mdash; everything you need for an
        unforgettable day on the water.
      </p>
      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="https://streambook.io/book/trigger-gap-outfitters" target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center rounded-lg bg-sunset px-8 py-3.5 text-lg font-semibold text-white shadow-lg transition hover:bg-sunset-dark hover:shadow-xl focus:outline-none focus:ring-2 focus:ring-sunset focus:ring-offset-2 focus:ring-offset-forest"
        >
          Book Your Trip
        </a>
        <a
          href={`${import.meta.env.BASE_URL}float-trips`}
          class="inline-flex items-center rounded-lg border-2 border-white px-8 py-3.5 text-lg font-semibold text-white transition hover:bg-white/10 focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-forest"
        >
          View Float Options
        </a>
      </div>
    </div>

    <!-- Wave SVG divider -->
    <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-none">
      <svg
        class="relative block h-16 w-full sm:h-24"
        viewBox="0 0 1200 120"
        preserveAspectRatio="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M0,40 C150,80 350,0 600,40 C850,80 1050,0 1200,40 L1200,120 L0,120 Z"
          fill="var(--color-warmwhite)"
        ></path>
      </svg>
    </div>
  </section>

  <!-- ============================== -->
  <!-- HIGHLIGHTS SECTION             -->
  <!-- ============================== -->
  <section class="bg-warmwhite py-20 sm:py-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        <!-- Card: Float Trip Options -->
        <div class="rounded-2xl bg-white p-8 shadow-sm transition hover:shadow-md">
          <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-full bg-river/10">
            <svg class="h-7 w-7 text-river" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498 4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 0 0-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0Z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-semibold text-forest">
            7 Float Trip Options
          </h3>
          <p class="mt-3 leading-relaxed text-earth/80">
            From quick half-day paddles to multi-day camping adventures, we
            offer seven distinct routes on the Kings River to match every
            skill level and schedule.
          </p>
        </div>

        <!-- Card: Premium Equipment -->
        <div class="rounded-2xl bg-white p-8 shadow-sm transition hover:shadow-md">
          <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-full bg-forest/10">
            <svg class="h-7 w-7 text-forest" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437 1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008Z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-semibold text-forest">
            Premium Equipment
          </h3>
          <p class="mt-3 leading-relaxed text-earth/80">
            We stock top-tier gear from Jackson Kayak, Mad River Canoe, and
            NRS. Well-maintained boats and quality life jackets ensure a safe,
            comfortable ride.
          </p>
        </div>

        <!-- Card: Swim at Trigger Gap -->
        <div class="rounded-2xl bg-white p-8 shadow-sm transition hover:shadow-md sm:col-span-2 lg:col-span-1">
          <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-full bg-river-light/20">
            <svg class="h-7 w-7 text-river" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 0 0 .495-7.468 5.99 5.99 0 0 0-1.925 3.547 5.975 5.975 0 0 1-2.133-1.001A3.75 3.75 0 0 0 12 18Z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-semibold text-forest">
            Swim at Trigger Gap
          </h3>
          <p class="mt-3 leading-relaxed text-earth/80">
            Our namesake swimming hole is one of the Kings River's most
            beloved spots. Guests enjoy free access to the bluffs, crystal-clear
            pools, and rope swing.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================== -->
  <!-- POPULAR TRIPS PREVIEW          -->
  <!-- ============================== -->
  <section class="bg-sand-light/50 py-20 sm:py-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="font-heading text-3xl font-bold text-forest sm:text-4xl">
          Popular Float Trips
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-earth/70">
          Choose your perfect day on the Kings River. Every rental includes
          shuttle service, life jackets, and paddles.
        </p>
      </div>

      <div class="mt-14 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        <!-- Trip Card: Rockhouse to Trigger Gap -->
        <div class="group overflow-hidden rounded-2xl bg-white shadow-sm transition hover:shadow-md">
          <!-- Placeholder: replace with actual photo -->
          <div class="relative h-52 bg-gradient-to-br from-forest via-river-dark to-river">
            <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
            <div class="absolute bottom-4 left-4 right-4">
              <span class="inline-block rounded-full bg-white/90 px-3 py-1 text-sm font-medium text-forest">
                7.7 miles &middot; 5&ndash;6 hrs
              </span>
            </div>
          </div>
          <div class="p-6">
            <h3 class="font-heading text-xl font-semibold text-forest">
              Rockhouse &rarr; Trigger Gap
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-earth/70">
              Our most scenic route. Navigate gentle rapids through towering
              bluffs and finish at the famous Trigger Gap swimming hole.
              Perfect for adventurous paddlers.
            </p>
            <a
              href={`${import.meta.env.BASE_URL}float-trips`}
              class="mt-4 inline-flex items-center text-sm font-semibold text-river transition hover:text-river-dark"
            >
              Learn More
              <svg class="ml-1 h-4 w-4 transition group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Trip Card: Trigger Gap to The Farm -->
        <div class="group overflow-hidden rounded-2xl bg-white shadow-sm transition hover:shadow-md">
          <!-- Placeholder: replace with actual photo -->
          <div class="relative h-52 bg-gradient-to-br from-river-light via-river to-forest">
            <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
            <div class="absolute bottom-4 left-4 right-4">
              <span class="inline-block rounded-full bg-white/90 px-3 py-1 text-sm font-medium text-forest">
                4.7 miles &middot; 4 hrs
              </span>
            </div>
          </div>
          <div class="p-6">
            <h3 class="font-heading text-xl font-semibold text-forest">
              Trigger Gap &rarr; The Farm
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-earth/70">
              An easygoing float ideal for families and first-timers. Calm
              stretches, beautiful scenery, and plenty of spots to stop and
              swim along the way.
            </p>
            <a
              href={`${import.meta.env.BASE_URL}float-trips`}
              class="mt-4 inline-flex items-center text-sm font-semibold text-river transition hover:text-river-dark"
            >
              Learn More
              <svg class="ml-1 h-4 w-4 transition group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Trip Card: Trigger Gap to 62 Bridge -->
        <div class="group overflow-hidden rounded-2xl bg-white shadow-sm transition hover:shadow-md sm:col-span-2 lg:col-span-1">
          <!-- Placeholder: replace with actual photo -->
          <div class="relative h-52 bg-gradient-to-br from-forest-light via-earth to-sunset-dark">
            <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
            <div class="absolute bottom-4 left-4 right-4">
              <span class="inline-block rounded-full bg-white/90 px-3 py-1 text-sm font-medium text-forest">
                12.9 miles &middot; 2 days
              </span>
            </div>
          </div>
          <div class="p-6">
            <h3 class="font-heading text-xl font-semibold text-forest">
              Trigger Gap &rarr; 62 Bridge
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-earth/70">
              The ultimate Kings River experience. Camp under the stars on a
              gravel bar and explore miles of pristine Ozark wilderness on this
              unforgettable two-day journey.
            </p>
            <a
              href={`${import.meta.env.BASE_URL}float-trips`}
              class="mt-4 inline-flex items-center text-sm font-semibold text-river transition hover:text-river-dark"
            >
              Learn More
              <svg class="ml-1 h-4 w-4 transition group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>

      <div class="mt-12 text-center">
        <a
          href={`${import.meta.env.BASE_URL}float-trips`}
          class="inline-flex items-center text-lg font-semibold text-river transition hover:text-river-dark"
        >
          View All Float Trips
          <svg class="ml-2 h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================== -->
  <!-- WHY CHOOSE US SECTION          -->
  <!-- ============================== -->
  <section class="bg-warmwhite py-20 sm:py-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
        <!-- Text column -->
        <div>
          <h2 class="font-heading text-3xl font-bold text-forest sm:text-4xl">
            Your Kings River Adventure Starts Here
          </h2>
          <ul class="mt-8 space-y-4">
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 shrink-0 text-river" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
              </svg>
              <span class="text-earth/80">Family-owned &amp; operated</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 shrink-0 text-river" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
              </svg>
              <span class="text-earth/80">Premium equipment from Jackson Kayak, Mad River &amp; NRS</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 shrink-0 text-river" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
              </svg>
              <span class="text-earth/80">Shuttle service included with every rental</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 shrink-0 text-river" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
              </svg>
              <span class="text-earth/80">Open 7 days a week, April through September</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 shrink-0 text-river" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
              </svg>
              <span class="text-earth/80">Famous Trigger Gap swimming hole</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 shrink-0 text-river" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
              </svg>
              <span class="text-earth/80">Trophy smallmouth bass fishing</span>
            </li>
          </ul>
          <div class="mt-10">
            <a
              href="https://streambook.io/book/trigger-gap-outfitters" target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center rounded-lg bg-sunset px-8 py-3.5 text-lg font-semibold text-white shadow-lg transition hover:bg-sunset-dark hover:shadow-xl focus:outline-none focus:ring-2 focus:ring-sunset focus:ring-offset-2"
            >
              Book Now
            </a>
          </div>
        </div>

        <!-- Placeholder image column -->
        <!-- Placeholder: replace with actual photo -->
        <div class="relative overflow-hidden rounded-2xl">
          <div class="aspect-[4/3] bg-gradient-to-br from-river-light via-river to-forest">
            <div class="absolute inset-0 bg-gradient-to-tl from-forest/40 via-transparent to-river-light/30"></div>
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="text-center text-white/60">
                <svg class="mx-auto h-16 w-16" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Zm16.5-13.5h.008v.008h-.008V7.5Zm0 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
                </svg>
                <p class="mt-2 text-sm font-medium">Photo placeholder</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================== -->
  <!-- CTA BANNER SECTION             -->
  <!-- ============================== -->
  <section class="relative overflow-hidden bg-river-dark py-20 sm:py-24">
    <!-- Decorative background -->
    <div class="absolute inset-0 bg-gradient-to-r from-forest/50 to-river-dark/80"></div>
    <div class="absolute inset-0 opacity-5 bg-[radial-gradient(circle_at_20%_50%,white_0%,transparent_50%)]"></div>

    <div class="relative z-10 mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-3xl font-bold text-white sm:text-4xl lg:text-5xl">
        Ready to Hit the Water?
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-lg text-white/85">
        Book online or call us at
        <a
          href="tel:+14792535444"
          class="font-semibold text-white underline decoration-white/40 underline-offset-2 transition hover:decoration-white"
        >
          479-253-5444
        </a>
      </p>
      <div class="mt-8">
        <a
          href="https://streambook.io/book/trigger-gap-outfitters" target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center rounded-lg bg-sunset px-8 py-3.5 text-lg font-semibold text-white shadow-lg transition hover:bg-sunset-dark hover:shadow-xl focus:outline-none focus:ring-2 focus:ring-sunset focus:ring-offset-2 focus:ring-offset-river-dark"
        >
          Book Your Trip
        </a>
      </div>
      <p class="mt-6 text-sm text-white/60">
        Must call 3 days in advance to check water levels.
      </p>
    </div>
  </section>
</Layout>
