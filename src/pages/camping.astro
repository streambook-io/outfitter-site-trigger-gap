---
import Layout from "../layouts/Layout.astro";

const campingRules = [
  {
    title: "Use Restrooms Provided",
    description: "Porta-potties are available on-site for your convenience. Please use them.",
    icon: "facility",
  },
  {
    title: "Dispose of Trash Properly",
    description: "Bag all trash and recycling. Pack out what you pack in.",
    icon: "trash",
  },
  {
    title: "Quiet Hours",
    description: "Please keep noise to a minimum before 7:00 AM and after 10:00 PM.",
    icon: "quiet",
  },
  {
    title: "Leave No Trace",
    description: "Leave your campsite better than you found it. Respect the river and surrounding land.",
    icon: "nature",
  },
];

const nearbyLodging = [
  {
    name: "RiverDream",
    description:
      "Luxury tent camping with direct river access. A unique glamping experience on the banks of the Kings River, combining outdoor adventure with comfort.",
    availability: "Available on Airbnb & VRBO",
  },
  {
    name: "At the River on Ironwood Lane B&B",
    description:
      "A charming bed and breakfast nestled along the Kings River. Comfortable accommodations with a warm, personal touch from your hosts.",
    availability: "Available on Airbnb & VRBO",
  },
  {
    name: "Dinner Bell Ranch Cabins",
    description:
      "Cozy cabins located within 5 miles of Trigger Gap Outfitters. A great option for groups or families wanting a full-service lodging experience.",
    availability: "Located within 5 miles",
  },
];
---

<Layout
  title="Camping & Lodging | Trigger Gap Outfitters"
  description="Primitive riverside camping on the Kings River and nearby lodging options in the Ozarks. $10/person/night at Trigger Gap Outfitters."
>
  <!-- Page Header -->
    <section class="relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-forest via-earth to-forest-light"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28 lg:py-36">
        <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-4">
          Camping & Lodging
        </h1>
        <p class="text-lg sm:text-xl text-sand-light/90 max-w-2xl">
          Sleep under the stars on the banks of the Kings River.
        </p>
      </div>
    </section>

    <!-- Riverside Camping Section -->
    <section class="py-16 sm:py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-start">
          <!-- Details Card -->
          <div class="bg-white rounded-xl shadow-md overflow-hidden">
            <div class="bg-gradient-to-r from-forest to-forest-light p-6 sm:p-8">
              <h2 class="font-heading text-2xl sm:text-3xl font-bold text-white mb-1">
                Riverside Camping
              </h2>
              <p class="text-sand-light/80">Primitive camping on the Kings River</p>
            </div>
            <div class="p-6 sm:p-8">
              <!-- Key Stats -->
              <div class="grid grid-cols-2 gap-4 mb-6">
                <div class="text-center p-4 bg-sand-light/40 rounded-lg">
                  <p class="font-heading text-3xl font-bold text-sunset">$10</p>
                  <p class="text-earth text-sm">per person / night</p>
                </div>
                <div class="text-center p-4 bg-sand-light/40 rounded-lg">
                  <p class="font-heading text-3xl font-bold text-forest">6</p>
                  <p class="text-earth text-sm">max per site</p>
                </div>
              </div>

              <!-- Feature List -->
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-forest flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class="text-earth">Approximately 7 designated primitive sites along the riverbank</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-forest flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class="text-earth">Porta-potties provided on-site</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-forest flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class="text-earth">Primitive -- no electricity or running water</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-forest flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class="text-earth">River customers receive priority for campsites</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-forest flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class="text-earth">Option to camp directly on the river bed</span>
                </li>
              </ul>

              <!-- Reservation Notice -->
              <div class="mt-6 p-4 bg-sunset/5 border border-sunset/20 rounded-lg">
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-sunset flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                  <div>
                    <p class="font-semibold text-forest text-sm">Reservations Required</p>
                    <p class="text-earth text-sm mt-1">
                      Call ahead to reserve your campsite:
                      <a href="tel:479-253-5444" class="text-river-dark font-medium hover:text-river transition-colors">
                        479-253-5444
                      </a>
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Placeholder Image -->
          <div class="aspect-[4/3] rounded-xl bg-gradient-to-br from-forest via-earth/60 to-sand-dark overflow-hidden shadow-lg">
            <div class="w-full h-full flex items-center justify-center">
              <div class="text-center text-white/60">
                <svg class="w-16 h-16 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <p class="text-sm font-medium">Riverside Camping</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Camping Rules / Etiquette -->
    <section class="py-16 sm:py-20 bg-sand-light/40">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="font-heading text-3xl sm:text-4xl font-bold text-forest mb-3">
            Campsite Rules & Etiquette
          </h2>
          <p class="text-earth-light text-lg max-w-xl mx-auto">
            Help us keep the Kings River beautiful for everyone.
          </p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-3xl mx-auto">
          {campingRules.map((rule) => (
            <div class="bg-white rounded-lg p-6 shadow-sm">
              <div class="flex items-start gap-4">
                <span class="flex-shrink-0 w-10 h-10 rounded-full bg-forest/10 flex items-center justify-center">
                  {rule.icon === "facility" && (
                    <svg class="w-5 h-5 text-forest" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                    </svg>
                  )}
                  {rule.icon === "trash" && (
                    <svg class="w-5 h-5 text-forest" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                  )}
                  {rule.icon === "quiet" && (
                    <svg class="w-5 h-5 text-forest" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  )}
                  {rule.icon === "nature" && (
                    <svg class="w-5 h-5 text-forest" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  )}
                </span>
                <div>
                  <h3 class="font-heading text-lg font-bold text-forest mb-1">
                    {rule.title}
                  </h3>
                  <p class="text-earth text-sm leading-relaxed">
                    {rule.description}
                  </p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Nearby Lodging Section -->
    <section class="py-16 sm:py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="font-heading text-3xl sm:text-4xl font-bold text-forest mb-3">
            Prefer a Roof Over Your Head?
          </h2>
          <p class="text-earth-light text-lg max-w-2xl mx-auto">
            These nearby lodging options offer comfortable accommodations close to the Kings River.
          </p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
          {nearbyLodging.map((lodge) => (
            <div class="bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow overflow-hidden">
              <!-- Placeholder image -->
              <div class="h-44 w-full bg-gradient-to-br from-sand-dark/50 via-earth-light/30 to-forest/20" />
              <div class="p-6">
                <h3 class="font-heading text-xl font-bold text-forest mb-2">
                  {lodge.name}
                </h3>
                <p class="text-earth text-sm leading-relaxed mb-4">
                  {lodge.description}
                </p>
                <p class="text-river-dark text-sm font-medium flex items-center gap-1.5">
                  <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  {lodge.availability}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Banner -->
    <section class="relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-r from-forest via-earth to-forest-light"></div>
      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20 text-center">
        <h2 class="font-heading text-3xl sm:text-4xl font-bold text-white mb-4">
          Book Your Camping Trip
        </h2>
        <p class="text-sand-light/90 text-lg mb-8 max-w-xl mx-auto">
          Reserve your riverside campsite and make the Kings River your home for the night.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="https://streambook.io/book/trigger-gap-outfitters" target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center px-8 py-4 bg-sunset text-white text-lg font-semibold rounded-lg hover:bg-sunset-dark transition-colors shadow-md hover:shadow-lg"
          >
            Book Now
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a
            href="tel:479-253-5444"
            class="inline-flex items-center px-8 py-4 bg-white/10 text-white text-lg font-semibold rounded-lg hover:bg-white/20 transition-colors border border-white/30"
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Call to Reserve
          </a>
        </div>
      </div>
    </section>
</Layout>
