---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="River Conditions | Trigger Gap Outfitters"
  description="Check Kings River water levels and conditions before your trip. View USGS gauge data and Arkansas river laws for a safe float."
>
  <!-- Page Header -->
  <section class="relative bg-gradient-to-br from-forest via-forest-light to-river-dark py-20 lg:py-28">
    <div class="absolute inset-0 bg-black/20"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-bold text-white">
        River Conditions
      </h1>
      <p class="mt-4 text-lg sm:text-xl text-sand-light/90 max-w-2xl mx-auto">
        Check water levels before planning your trip.
      </p>
    </div>
  </section>

  <!-- Important Notice -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 -mt-8 relative z-10">
    <div class="bg-white border-l-4 border-river rounded-lg shadow-lg p-6 sm:p-8">
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0 mt-0.5">
          <svg class="w-7 h-7 text-river-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div>
          <h2 class="font-heading text-xl sm:text-2xl font-bold text-forest">
            Call for Real-Time Conditions
          </h2>
          <p class="mt-2 text-earth text-base sm:text-lg">
            Always call us at
            <a href="tel:479-253-5444" class="font-semibold text-river-dark hover:text-river transition-colors">
              479-253-5444
            </a>
            for the most accurate, real-time water conditions before heading out.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Gauge Links -->
  <section class="py-16 lg:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-3xl sm:text-4xl font-bold text-forest text-center mb-10">
        Water Level Resources
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 lg:gap-8">
        <!-- USGS Gauge -->
        <a
          href="http://water.weather.gov/ahps2/hydrograph.php?wfo=tsa&gage=brya4"
          target="_blank"
          rel="noopener noreferrer"
          class="group block bg-white rounded-xl shadow-sm border border-sand/40 p-6 sm:p-8 hover:shadow-md hover:border-river/40 transition-all"
        >
          <div class="flex items-start justify-between gap-4">
            <div>
              <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-river/10 mb-4">
                <svg class="w-6 h-6 text-river-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                </svg>
              </div>
              <h3 class="font-heading text-xl font-bold text-forest group-hover:text-river-dark transition-colors">
                USGS River Gauge
              </h3>
              <p class="mt-2 text-earth">
                Kings River near Berryville &mdash; live hydrograph data from the National Weather Service.
              </p>
            </div>
            <svg class="w-5 h-5 text-sand-dark group-hover:text-river-dark transition-colors flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </div>
        </a>

        <!-- Weather Forecast -->
        <a
          href="http://weather.com"
          target="_blank"
          rel="noopener noreferrer"
          class="group block bg-white rounded-xl shadow-sm border border-sand/40 p-6 sm:p-8 hover:shadow-md hover:border-river/40 transition-all"
        >
          <div class="flex items-start justify-between gap-4">
            <div>
              <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-river/10 mb-4">
                <svg class="w-6 h-6 text-river-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" />
                </svg>
              </div>
              <h3 class="font-heading text-xl font-bold text-forest group-hover:text-river-dark transition-colors">
                Weather Forecast
              </h3>
              <p class="mt-2 text-earth">
                Check the local weather before heading out for the best river experience.
              </p>
            </div>
            <svg class="w-5 h-5 text-sand-dark group-hover:text-river-dark transition-colors flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Arkansas River Laws -->
  <section class="py-16 lg:py-20 bg-sand-light/40">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-3xl sm:text-4xl font-bold text-forest text-center mb-4">
        Arkansas River Laws
      </h2>
      <p class="text-earth text-center max-w-2xl mx-auto mb-10">
        These rules are required by Arkansas state law. We take them seriously to protect the Kings River for everyone.
      </p>
      <div class="bg-white rounded-xl shadow-sm border border-sand/40 divide-y divide-sand/30">
        {[
          {
            allowed: false,
            text: "No glass containers on the river",
          },
          {
            allowed: true,
            text: "All boats must have a recycling bag (provided by outfitter)",
          },
          {
            allowed: true,
            text: "Coolers must have a fastened lid or be tied down",
          },
          {
            allowed: false,
            text: "No Styrofoam coolers",
          },
          {
            allowed: true,
            text: "All can beverages must be in a floating holder",
          },
          {
            allowed: true,
            text: "All boats must have life jackets for each person",
          },
        ].map((rule) => (
          <div class="flex items-start gap-4 px-6 py-5">
            {rule.allowed ? (
              <svg class="w-6 h-6 text-river flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            ) : (
              <svg class="w-6 h-6 text-sunset flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            )}
            <p class:list={[
              "text-base sm:text-lg",
              rule.allowed ? "text-earth" : "text-sunset-dark font-medium",
            ]}>
              {rule.text}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 lg:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-2xl sm:text-3xl font-bold text-forest mb-4">
        Questions About Conditions?
      </h2>
      <p class="text-earth text-lg mb-8">
        We're happy to help you plan a safe and fun trip on the Kings River.
      </p>
      <a
        href="tel:479-253-5444"
        class="inline-flex items-center gap-3 px-8 py-4 bg-sunset text-white text-lg font-semibold rounded-lg hover:bg-sunset-dark transition-colors shadow-md hover:shadow-lg"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        Call 479-253-5444
      </a>
    </div>
  </section>
</Layout>
